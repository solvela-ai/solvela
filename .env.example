# Solvela environment variables
# Copy to .env and fill in your values.
#
# Quick start (local dev):
#   docker compose up -d        # start Postgres + Redis
#   cp .env.example .env
#   # fill in at least one provider API key below
#   cargo run -p gateway

# ── Environment ─────────────────────────────────────────────────────────────────
# Set to "production" or "prod" to enforce strict security checks
# (require valid Solana config, warn on missing sslmode, etc.)
SOLVELA_ENV=development
# Deprecated: RCR_ENV=development

# ── Dev-mode payment bypass ──────────────────────────────────────────────────
# Set to "true" to skip payment verification on /v1/chat/completions.
# Allows testing LLM responses without a Solana wallet.
# ONLY works when SOLVELA_ENV is NOT "production" — ignored entirely in prod.
# Default: false (must be explicitly opted in, even in development).
# SOLVELA_DEV_BYPASS_PAYMENT=true
# Deprecated: RCR_DEV_BYPASS_PAYMENT

# ── Server ────────────────────────────────────────────────────────────────────
SOLVELA_HOST=0.0.0.0
SOLVELA_PORT=8402
# Deprecated: RCR_SERVER_HOST, RCR_SERVER_PORT

# ── Solana ────────────────────────────────────────────────────────────────────
# RPC endpoint — use devnet for development, mainnet-beta for production
SOLVELA_SOLANA_RPC_URL=https://api.devnet.solana.com
# Your gateway's USDC recipient wallet (base58 pubkey)
SOLVELA_SOLANA_RECIPIENT_WALLET=
# Hot wallet private key (base58) used to co-sign/pay transaction fees
# NEVER commit this value — keep it in .env only
SOLVELA_SOLANA_FEE_PAYER_KEY=
# Optional — enables escrow payment mode.
# When set (along with FEE_PAYER_KEY), 402 responses will offer both "exact"
# and "escrow" schemes. The gateway will fire claim transactions after serving.
# Mainnet program ID: 9neDHouXgEgHZDde5SpmqqEZ9Uv35hFcjtFEPxomtHLU
SOLVELA_SOLANA_ESCROW_PROGRAM_ID=
# Deprecated: RCR_SOLANA_RPC_URL, RCR_SOLANA_RECIPIENT_WALLET, RCR_SOLANA_FEE_PAYER_KEY, RCR_SOLANA_ESCROW_PROGRAM_ID

# ── LLM Provider API keys ─────────────────────────────────────────────────────
# At least one key is required for the gateway to serve real completions.
# Providers without a key fall back to the stub FallbackProvider (returns 503).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ── PostgreSQL (optional — enables persistent spend logging) ──────────────────
# Without this, spend events are logged to stdout only.
# docker compose up -d postgres  → starts Postgres with these credentials.
# WARNING: Default credentials — for local development only. Never use in production.
# For production, append ?sslmode=require to enforce encrypted connections:
#   DATABASE_URL=postgres://solvela:password@db.example.com:5432/solvela?sslmode=require
DATABASE_URL=postgres://solvela:solvela_dev_password@localhost:5432/solvela

# ── Redis (optional — enables response cache + replay protection) ──────────────
# Without this, every request hits the upstream provider; replay protection
# falls back to fail-open (logged but not blocked).
# docker compose up -d redis  → starts Redis on the default port.
REDIS_URL=redis://localhost:6379

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# localhost:3000 and localhost:8080 are always allowed in development.
# SOLVELA_CORS_ORIGINS=https://dashboard.solvela.ai
# Deprecated: RCR_CORS_ORIGINS

# ── Security ───────────────────────────────────────────────────────────────────
# Admin token for protected endpoints (e.g., /admin/services).
# Generate with: openssl rand -hex 32
# SOLVELA_ADMIN_TOKEN=
# Deprecated: RCR_ADMIN_TOKEN

# Session secret for HMAC-SHA256 signing (base64-encoded, min 32 bytes).
# If not set, a random ephemeral secret is generated on each startup
# (sessions will not survive restarts).
# Generate with: openssl rand -base64 32
# SOLVELA_SESSION_SECRET=
# Deprecated: RCR_SESSION_SECRET

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=gateway=info,tower_http=info
