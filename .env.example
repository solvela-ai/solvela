# RustyClawRouter environment variables
# Copy to .env and fill in your values.
#
# Quick start (local dev):
#   docker compose up -d        # start Postgres + Redis
#   cp .env.example .env
#   # fill in at least one provider API key below
#   cargo run -p gateway

# ── Server ────────────────────────────────────────────────────────────────────
RCR_SERVER_HOST=0.0.0.0
RCR_SERVER_PORT=8402

# ── Solana ────────────────────────────────────────────────────────────────────
# RPC endpoint — use devnet for development, mainnet-beta for production
RCR_SOLANA_RPC_URL=https://api.devnet.solana.com
# Your gateway's USDC recipient wallet (base58 pubkey)
RCR_SOLANA_RECIPIENT_WALLET=
# Hot wallet private key (base58) used to co-sign/pay transaction fees
# NEVER commit this value — keep it in .env only
RCR_SOLANA_FEE_PAYER_KEY=
# Optional — enables escrow payment mode. The value below is a devnet example only.
# When set (along with FEE_PAYER_KEY), 402 responses will offer both "exact"
# and "escrow" schemes. The gateway will fire claim transactions after serving.
# Example (devnet): GTs7ik3NbW3xwSXq33jyVRGgmshNEyW1h9rxDNATiFLy
RCR_SOLANA_ESCROW_PROGRAM_ID=

# ── LLM Provider API keys ─────────────────────────────────────────────────────
# At least one key is required for the gateway to serve real completions.
# Providers without a key fall back to the stub FallbackProvider (returns 503).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# ── PostgreSQL (optional — enables persistent spend logging) ──────────────────
# Without this, spend events are logged to stdout only.
# docker compose up -d postgres  → starts Postgres with these credentials.
# WARNING: Default credentials — for local development only. Never use in production.
DATABASE_URL=postgres://rcr:rcr_dev_password@localhost:5432/rustyclawrouter

# ── Redis (optional — enables response cache + replay protection) ──────────────
# Without this, every request hits the upstream provider; replay protection
# falls back to fail-open (logged but not blocked).
# docker compose up -d redis  → starts Redis on the default port.
REDIS_URL=redis://localhost:6379

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# localhost:3000 and localhost:8080 are always allowed in development.
# RCR_CORS_ORIGINS=https://dashboard.rustyclawrouter.com

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=gateway=info,tower_http=info
