{
  "name": "solvela-dark",
  "type": "dark",
  "colors": {
    "editor.background": "#30302E",
    "editor.foreground": "#DEDCD1"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#6E6D67", "fontStyle": "italic" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#2C84DB" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#65BB30" }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": { "foreground": "#FE8181" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#FE8181" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#74ABE2" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#FAF9F5" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#DEDCD1" }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object-literal.key string",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#74ABE2" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#9B9A93" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.arithmetic", "keyword.operator.assignment"],
      "settings": { "foreground": "#9B9A93" }
    },
    {
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#2C84DB" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#74ABE2" }
    },
    {
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": { "foreground": "#65BB30" }
    },
    {
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": { "foreground": "#FE8181" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#FAF9F5", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#74ABE2", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#2C84DB", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#FE8181" }
    }
  ]
}
