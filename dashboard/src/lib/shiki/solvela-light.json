{
  "name": "solvela-light",
  "type": "light",
  "colors": {
    "editor.background": "#EAEAE6",
    "editor.foreground": "#262624"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8A8880", "fontStyle": "italic" }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#1F6CB8" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#3F7A1F" }
    },
    {
      "scope": ["string.regexp", "constant.character.escape"],
      "settings": { "foreground": "#C85555" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": { "foreground": "#C85555" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function",
        "variable.function"
      ],
      "settings": { "foreground": "#3A6E9E" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#1F1E1D" }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": { "foreground": "#262624" }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.object-literal.key string",
        "support.type.property-name"
      ],
      "settings": { "foreground": "#3A6E9E" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#6B6A65" }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.arithmetic", "keyword.operator.assignment"],
      "settings": { "foreground": "#6B6A65" }
    },
    {
      "scope": ["entity.name.tag", "meta.tag"],
      "settings": { "foreground": "#1F6CB8" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#3A6E9E" }
    },
    {
      "scope": ["markup.inserted", "markup.inserted.diff"],
      "settings": { "foreground": "#3F7A1F" }
    },
    {
      "scope": ["markup.deleted", "markup.deleted.diff"],
      "settings": { "foreground": "#C85555" }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#1F1E1D", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#3A6E9E", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": { "foreground": "#1F6CB8", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#C85555" }
    }
  ]
}
